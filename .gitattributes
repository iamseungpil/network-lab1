# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf
docker-scripts/*.sh text eol=lf

# Python files
*.py text eol=lf

# Dockerfiles
Dockerfile text eol=lf
.dockerignore text eol=lf

# Force batch scripts to use CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf

# Markdown files
*.md text eol=lf

# Config files
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
requirements.txt text eol=lf
